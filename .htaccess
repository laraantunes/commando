AuthType Basic
AuthName "Acesso Restrito - Commando"
AuthUserFile "d:/Lara/xampp8.2/htdocs/commando/.htpasswd"
Require valid-user

# Protege arquivos de configuração, dotfiles e scripts sensíveis contra acesso direto via URL
<FilesMatch "(^\.|^composer\.(json|lock)$)">
    Require all denied
</FilesMatch>
